# Frontend (Vite)
# For local dev, leave VITE_API_BASE_URL empty (Vite proxy handles it).
# For Vercel (frontend-only), set this to your Render backend URL:
#   e.g. https://tokenflow-os.onrender.com
VITE_AUTH0_DOMAIN=dev-3e6vshkujhbxcy4n.us.auth0.com
VITE_AUTH0_CLIENT_ID=N5vRRWiZEQ3AoUWbgdTqehMIvDrRvcgo
VITE_AUTH0_AUDIENCE=https://fairact-api
VITE_AUTH0_SCOPE=openid profile email read:data run:ai execute:action
# For local dev: leave empty or set to http://localhost:8000 (Vite proxy handles it).
# For Vercel: set this in the Vercel dashboard to your Render backend URL.
VITE_API_BASE_URL=

# Auth0
AUTH0_DOMAIN=dev-3e6vshkujhbxcy4n.us.auth0.com
AUTH0_AUDIENCE=https://fairact-api
AUTH0_ISSUER=https://dev-3e6vshkujhbxcy4n.us.auth0.com/
AUTH0_CLIENT_ID=N5vRRWiZEQ3AoUWbgdTqehMIvDrRvcgo
AUTH0_CLIENT_SECRET=

# Auth0 Custom API Client (required only for Token Vault exchange)
AUTH0_CUSTOM_API_CLIENT_ID=
AUTH0_CUSTOM_API_CLIENT_SECRET=

# Optional integrations
OPENAI_API_KEY=
SENDGRID_API_KEY=

# App configuration
# PORT: Render uses 10000 by default, local dev uses 8000
PORT=8000
DATABASE_URL=./tokenflow.db
NODE_ENV=development
# FRONTEND_ORIGIN: comma-separated allowed origins for CORS
# For production, set to your Vercel URL: https://tokenflow-os.vercel.app
# You can list multiple: https://tokenflow-os.vercel.app,https://custom-domain.com
FRONTEND_ORIGIN=http://localhost:5173
FAIRNESS_THRESHOLD=0.20

# Feature flags
USE_REAL_OPENAI=false
USE_REAL_SENDGRID=false
USE_AUTH0=true

# Fairness Execution Gate
# 'shadow' = compute+log gate decision but don't block mission workflows (default)
# 'enforce' = hard-block mission workflows when fairness state is unsafe
FAIRNESS_GATE_MODE=shadow
# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Add your Google Gemini API key below to enable AI-powered fairness report generation.
# Get your key at: https://aistudio.google.com/app/apikey
# Once added, the "Generate AI Report" button in the Fairness page will produce
# a full narrative analysis using Gemini Flash instead of the deterministic template.
# Leave blank to use deterministic reports (always works, no API needed).
GEMINI_API_KEY=

# LLM provider abstraction (for supervisor explanations and future orchestration tasks)
# Choose provider: gemini | gemma
LLM_PROVIDER=gemini
# Gemini default model
LLM_MODEL_GEMINI=gemini-2.5-flash
# Gemma model name to use when LLM_PROVIDER=gemma
LLM_MODEL_GEMMA=gemma-3-27b-it
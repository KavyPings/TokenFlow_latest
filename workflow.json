{
  "name": "Loan Approval Decision Pipeline",
  "description": "Workflow for processing loan applications, scoring, fairness check, and audit logging",
  "agent": "enterprise-ai-worker",
  "steps": [
    {
      "action": "READ_OBJECT",
      "service": "gcs",
      "resource": "loan_applications/batch_2026_04.json",
      "actionVerb": "read"
    },
    {
      "action": "CALL_INTERNAL_API",
      "service": "internal-api",
      "resource": "api/v1/credit-score",
      "actionVerb": "invoke"
    },
    {
      "action": "FAIRNESS_CHECK",
      "service": "fairness-engine",
      "resource": "loan_applications/batch_2026_04.json",
      "actionVerb": "evaluate"
    },
    {
      "action": "WRITE_OBJECT",
      "service": "gcs",
      "resource": "loan_decisions/decisions_2026_04.json",
      "actionVerb": "write"
    },
    {
      "action": "SEND_EMAIL",
      "service": "email",
      "resource": "applicant_notification_service",
      "actionVerb": "send"
    },
    {
      "action": "WRITE_AUDIT_LOG",
      "service": "audit-log",
      "resource": "audit/loan_pipeline_2026_04.json",
      "actionVerb": "write"
    }
  ]
}